@model BioGamaEcuador.Models.Researcher
@{ ViewData["Title"] = Model.Name; }

<div class="mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fa-solid fa-arrow-left me-1"></i>Volver al listado</a>
</div>
<div class="card shadow-sm">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0"><i class="fa-solid fa-microscope me-2"></i>@Model.Name</h5>
    </div>
    <div class="card-body">
        <div class="row g-3 mb-3">
            <div class="col-md-4">
                <div class="card border-0 bg-light p-3 text-center h-100">
                    <div style="font-size:2rem;"><i class="fa-solid fa-building-columns text-primary"></i></div>
                    <div class="small text-muted mt-1">Institución</div>
                    <div class="fw-bold">@Model.Institution</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 bg-light p-3 text-center h-100">
                    <div style="font-size:2rem;"><i class="fa-solid fa-flask text-success"></i></div>
                    <div class="small text-muted mt-1">Especialidad</div>
                    <div class="fw-bold">@Model.Specialty</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 bg-light p-3 text-center h-100">
                    <div style="font-size:2rem;"><i class="fa-solid fa-envelope text-danger"></i></div>
                    <div class="small text-muted mt-1">Correo</div>
                    <div class="fw-bold"><a href="mailto:@Model.Email">@Model.Email</a></div>
                </div>
            </div>
        </div>
        <dl class="row mb-0">
            <dt class="col-sm-4"><i class="fa-solid fa-calendar-days me-1 text-muted"></i>Registrado el</dt>
            <dd class="col-sm-8">@Model.CreatedAt.ToString("dd/MM/yyyy")</dd>
        </dl>
        <div class="mt-4 d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm"><i class="fa-solid fa-pen me-1"></i>Editar</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm"><i class="fa-solid fa-trash me-1"></i>Eliminar</a>
        </div>
    </div>
</div>
