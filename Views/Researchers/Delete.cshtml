@model BioGamaEcuador.Models.Researcher

@{
    ViewData["Title"] = "Eliminar investigador";
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Investigadores</a></li>
            <li class="breadcrumb-item active" aria-current="page">Eliminar</li>
        </ol>
    </nav>

    <div class="card shadow-sm border-0">
        <div class="card-body text-center py-5">
            <i class="fa-regular fa-circle-exclamation text-danger" style="font-size:3rem;"></i>
            <h4 class="mt-3">¿Está seguro de que desea eliminar este investigador?</h4>
            <p class="text-muted mb-4">Esta acción desactivará el investigador. No se eliminará permanentemente.</p>

            <dl class="row text-start mx-auto" style="max-width:500px;">
                <dt class="col-sm-5 text-muted">Nombre</dt>
                <dd class="col-sm-7">@Model.Name</dd>
                <dt class="col-sm-5 text-muted">Institución</dt>
                <dd class="col-sm-7">@Model.Institution</dd>
                <dt class="col-sm-5 text-muted">Correo electrónico</dt>
                <dd class="col-sm-7">@Model.Email</dd>
                <dt class="col-sm-5 text-muted">Especialidad</dt>
                <dd class="col-sm-7">@Model.Specialty</dd>
            </dl>

            <form asp-action="Delete" class="mt-4">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger me-2"><i class="fa-regular fa-trash-can me-1"></i>Eliminar</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </form>
        </div>
    </div>
</div>
