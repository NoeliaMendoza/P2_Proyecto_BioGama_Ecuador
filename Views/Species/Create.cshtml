@model BioGamaEcuador.Models.Species

@{
    ViewData["Title"] = "Nueva Especie";
}

<h2>Nueva Especie</h2>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group mb-3">
                <label asp-for="CommonName" class="control-label">Nombre común</label>
                <input asp-for="CommonName" class="form-control" />
                <span asp-validation-for="CommonName" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="ScientificName" class="control-label">Nombre científico</label>
                <input asp-for="ScientificName" class="form-control" />
                <span asp-validation-for="ScientificName" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="ConservationStatus" class="control-label">Estado de conservación</label>
                <input asp-for="ConservationStatus" class="form-control" />
                <span asp-validation-for="ConservationStatus" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Description" class="control-label">Descripción</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="ImageUrl" class="control-label">URL de imagen</label>
                <input asp-for="ImageUrl" class="form-control" />
                <span asp-validation-for="ImageUrl" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="FamilyId" class="control-label">Familia <span class="text-danger">*</span></label>
                <select asp-for="FamilyId" class="form-control" asp-items="ViewBag.FamilyId">
                    <option value="0">-- Seleccione una familia --</option>
                </select>
                <span asp-validation-for="FamilyId" class="text-danger"></span>
            </div>
            <div class="form-check mb-3">
                <input class="form-check-input" asp-for="IsEndemic" />
                <label class="form-check-label" asp-for="IsEndemic">Endémica</label>
            </div>
            <div class="form-group">
                <input type="submit" value="Guardar" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
