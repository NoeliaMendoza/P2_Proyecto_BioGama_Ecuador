@model List<BioGamaEcuador.Models.Species>

@{
    ViewData["Title"] = "Especies";
}

<div class="mb-3">
    <div class="d-flex justify-content-between align-items-center">
        <h2>Especies <span class="badge bg-secondary ms-2">Total: @ViewBag.TotalItems</span></h2>
        @if (User.IsInRole("Administrador") || User.IsInRole("Investigador"))
        {
            <a class="btn btn-primary btn-sm" asp-action="Create">Crear nueva</a>
        }
    </div>

    <form method="get" asp-action="Index" class="mt-3">
        <div class="row g-2">
            <div class="col-12 col-md-4">
                <input type="text" name="busqueda" class="form-control"
                       placeholder="Buscar por nombre común o científico…" value="@ViewBag.Busqueda" />
            </div>
            <div class="col-6 col-md-2">
                <select name="familia" class="form-select">
                    <option value="">Todas las familias</option>
                    @foreach (var f in (List<string>?)ViewBag.Familias ?? new List<string>())
                    {
                        <option value="@f" selected="@(ViewBag.FamiliaFiltro == f)">@f</option>
                    }
                </select>
            </div>
            <div class="col-6 col-md-2">
                <select name="estado" class="form-select">
                    <option value="">Todos los estados</option>
                    @foreach (var e in (List<string>?)ViewBag.Estados ?? new List<string>())
                    {
                        <option value="@e" selected="@(ViewBag.EstadoFiltro == e)">@e</option>
                    }
                </select>
            </div>
            <div class="col-6 col-md-2">
                <select name="endemica" class="form-select">
                    <option value="">Todas</option>
                    <option value="true" selected="@(ViewBag.EndémicaFiltro == true)">Sí</option>
                    <option value="false" selected="@(ViewBag.EndémicaFiltro == false)">No</option>
                </select>
            </div>
            <div class="col-6 col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-outline-secondary w-100">Filtrar</button>
                <a asp-action="Index" class="btn btn-outline-secondary w-100">Limpiar</a>
            </div>
        </div>
    </form>
</div>
<div class="table-responsive">
    <table class="table table-striped table-hover table-bordered align-middle">
        <thead class="table-light">
            <tr>
                <th>Nombre común</th>
                <th>Nombre científico</th>
                <th>Estado</th>
                <th>Endémica</th>
                <th>Familia</th>
                <th>Creado</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.CommonName</td>
                    <td><em>@item.ScientificName</em></td>
                    <td>@item.ConservationStatus</td>
                    <td>@item.IsEndemic</td>
                    <td>@item.Family?.Name</td>
                    <td>@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                    <td>
                        <div class="btn-group" role="group">
                            @if (User.IsInRole("Administrador") || User.IsInRole("Investigador"))
                            {
                                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Editar</a>
                            }
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Ver</a>
                            @if (User.IsInRole("Administrador"))
                            {
                                <a class="btn btn-sm btn-outline-danger" asp-action="Delete"
                                   asp-route-id="@item.Id">Eliminar</a>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<nav class="mt-3" aria-label="Paginación">
    <ul class="pagination justify-content-center">
        @{
            int paginaActual = (int)ViewBag.PaginaActual;
            int totalPaginas = (int)ViewBag.TotalPaginas;
            int rango = 9;
            int inicio = Math.Max(1, paginaActual - rango);
            int fin = Math.Min(totalPaginas, paginaActual + rango);
        }

        @* « Primera *@
        <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
            <a class="page-link" asp-action="Index" asp-route-pagina="1" asp-route-busqueda="@ViewBag.Busqueda"
               asp-route-familia="@ViewBag.FamiliaFiltro" asp-route-estado="@ViewBag.EstadoFiltro"
               asp-route-endemica="@(ViewBag.EndémicaFiltro == null ? "" : (ViewBag.EndémicaFiltro == true ? "true" : "false"))">&laquo;</a>
        </li>

        @* ‹ Anterior *@
        <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
            <a class="page-link" asp-action="Index" asp-route-pagina="@(paginaActual - 1)"
               asp-route-busqueda="@ViewBag.Busqueda" asp-route-familia="@ViewBag.FamiliaFiltro"
               asp-route-estado="@ViewBag.EstadoFiltro"
               asp-route-endemica="@(ViewBag.EndémicaFiltro == null ? "" : (ViewBag.EndémicaFiltro == true ? "true" : "false"))">&lsaquo;</a>
        </li>

        @* … izquierdo *@
        @if (inicio > 1)
        {
            <li class="page-item disabled"><span class="page-link">…</span></li>
        }

        @* Rango central *@
        @for (int i = inicio; i <= fin; i++)
        {
            <li class="page-item @(i == paginaActual ? "active" : "")">
                <a class="page-link" asp-action="Index" asp-route-pagina="@i" asp-route-busqueda="@ViewBag.Busqueda"
                   asp-route-familia="@ViewBag.FamiliaFiltro" asp-route-estado="@ViewBag.EstadoFiltro"
                   asp-route-endemica="@(ViewBag.EndémicaFiltro == null ? "" : (ViewBag.EndémicaFiltro == true ? "true" : "false"))">@i</a>
            </li>
        }

        @* … derecho *@
        @if (fin < totalPaginas)
        {
            <li class="page-item disabled"><span class="page-link">…</span></li>
        }

        @* › Siguiente *@
        <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
            <a class="page-link" asp-action="Index" asp-route-pagina="@(paginaActual + 1)"
               asp-route-busqueda="@ViewBag.Busqueda" asp-route-familia="@ViewBag.FamiliaFiltro"
               asp-route-estado="@ViewBag.EstadoFiltro"
               asp-route-endemica="@(ViewBag.EndémicaFiltro == null ? "" : (ViewBag.EndémicaFiltro == true ? "true" : "false"))">&rsaquo;</a>
        </li>

        @* » Última *@
        <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
            <a class="page-link" asp-action="Index" asp-route-pagina="@totalPaginas"
               asp-route-busqueda="@ViewBag.Busqueda" asp-route-familia="@ViewBag.FamiliaFiltro"
               asp-route-estado="@ViewBag.EstadoFiltro"
               asp-route-endemica="@(ViewBag.EndémicaFiltro == null ? "" : (ViewBag.EndémicaFiltro == true ? "true" : "false"))">&raquo;</a>
        </li>
    </ul>
    <p class="text-center text-muted small">Página @ViewBag.PaginaActual de @ViewBag.TotalPaginas</p>
</nav>
