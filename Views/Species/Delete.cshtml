@model BioGamaEcuador.Models.Species

@{
    ViewData["Title"] = "Eliminar especie";
}

<div class="row justify-content-center py-4">
    <div class="col-md-8">
        <div class="card border-secondary shadow-sm">
            <div class="card-body">
                <h2 class="card-title mb-3">Confirmar eliminación</h2>
                <p class="text-muted">Estás a punto de eliminar la especie. Esta acción no se puede deshacer.</p>

                <div class="mt-4">
                    <dl class="row">
                        <dt class="col-sm-4 text-muted">Nombre común</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.CommonName)</dd>

                        <dt class="col-sm-4 text-muted">Nombre científico</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.ScientificName)</dd>

                        <dt class="col-sm-4 text-muted">Estado</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.ConservationStatus)</dd>

                        <dt class="col-sm-4 text-muted">Familia</dt>
                        <dd class="col-sm-8">@Model.Family?.Name ?? "—"</dd>
                    </dl>
                </div>

                <hr />

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex flex-wrap gap-2">
                        <button type="submit" class="btn btn-danger">Eliminar definitivamente</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
