@model BioGamaEcuador.Models.Family

@{
    ViewData["Title"] = "Nueva Familia";
}

<h2>Nueva Familia</h2>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label">Nombre de la familia</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Kingdom" class="control-label">Reino</label>
                <select asp-for="Kingdom" class="form-control">
                    <option value="">-- Seleccione un reino --</option>
                    <option value="Animal">Animal</option>
                    <option value="Vegetal">Vegetal</option>
                    <option value="Fungi">Fungi</option>
                </select>
                <span asp-validation-for="Kingdom" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Guardar" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
