@model BioGamaEcuador.Models.Family
@{ ViewData["Title"] = Model.Name; }

<div class="mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fa-solid fa-arrow-left me-1"></i>Volver al listado</a>
</div>
<div class="card shadow-sm">
    <div class="card-header bg-warning text-dark">
        <h5 class="mb-0"><i class="fa-solid fa-dna me-2"></i>@Model.Name</h5>
    </div>
    <div class="card-body">
        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <div class="card border-0 bg-light p-3 text-center h-100">
                    <div style="font-size:2rem;"><i class="fa-solid fa-crown text-warning"></i></div>
                    <div class="small text-muted mt-1">Reino</div>
                    <div class="fw-bold fs-5">@Model.Kingdom</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card border-0 bg-light p-3 text-center h-100">
                    <div style="font-size:2rem;"><i class="fa-solid fa-calendar-days text-secondary"></i></div>
                    <div class="small text-muted mt-1">Registrado el</div>
                    <div class="fw-bold">@Model.CreatedAt.ToString("dd/MM/yyyy")</div>
                </div>
            </div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm"><i class="fa-solid fa-pen me-1"></i>Editar</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm"><i class="fa-solid fa-trash me-1"></i>Eliminar</a>
        </div>
    </div>
</div>
