@model BioGamaEcuador.Models.NaturalReserve

@{
    ViewData["Title"] = "Nueva Reserva Natural";
}

<h2>Nueva Reserva Natural</h2>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label">Nombre</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Region" class="control-label">Región natural</label>
                <select asp-for="Region" class="form-control">
                    <option value="">-- Seleccione una región --</option>
                    <option value="Costa">Costa</option>
                    <option value="Sierra">Sierra</option>
                    <option value="Amazonía">Amazonía</option>
                    <option value="Galápagos">Galápagos</option>
                </select>
                <span asp-validation-for="Region" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="SurfaceHectares" class="control-label">Superficie (ha)</label>
                <input asp-for="SurfaceHectares" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="SurfaceHectares" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="YearCreated" class="control-label">Año de creación</label>
                <input asp-for="YearCreated" class="form-control" type="number" min="1900" max="2100" />
                <span asp-validation-for="YearCreated" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Description" class="control-label">Descripción</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Guardar" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
