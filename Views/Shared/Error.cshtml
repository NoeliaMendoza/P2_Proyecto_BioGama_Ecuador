@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<h1 class="text-danger">Error.</h1>
<h2 class="text-danger">Ocurrió un error al procesar su solicitud.</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>ID de solicitud:</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>Modo de desarrollo</h3>
<p>
    Al cambiar al entorno de <strong>Desarrollo</strong> se mostrará información más detallada sobre el error que ocurrió.
</p>
<p>
    <strong>El entorno de desarrollo no debe estar habilitado para aplicaciones implementadas.</strong>
    Puede resultar en la visualización de información sensible de excepciones a los usuarios finales.
    Para depuración local, habilite el entorno de <strong>Desarrollo</strong> configurando la variable de entorno <strong>ASPNETCORE_ENVIRONMENT</strong> en <strong>Development</strong>
    y reiniciando la aplicación.
</p>
