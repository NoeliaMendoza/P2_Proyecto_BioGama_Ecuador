@{
    ViewData["Title"] = "Reportes";
    var resumen = ViewBag.Resumen;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 text-secondary"><i class="fa-regular fa-chart-bar me-2"></i>Reportes</h4>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="border rounded p-3 bg-white">
            <div class="small text-muted">Especies</div>
            <div class="fs-4 fw-semibold">@resumen.TotalEspecies</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="border rounded p-3 bg-white">
            <div class="small text-muted">Registros</div>
            <div class="fs-4 fw-semibold">@resumen.TotalRegistros</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="border rounded p-3 bg-white">
            <div class="small text-muted">Investigadores</div>
            <div class="fs-4 fw-semibold">@resumen.TotalInvestigadores</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="border rounded p-3 bg-white">
            <div class="small text-muted">Reservas</div>
            <div class="fs-4 fw-semibold">@resumen.TotalReservas</div>
        </div>
    </div>
</div>

<div class="row g-3">

    <div class="col-md-6">
        <div class="border rounded bg-white">
            <div class="px-3 py-2 border-bottom bg-light bg-opacity-50">
                <span class="fw-medium small text-uppercase text-muted">Registros por región</span>
            </div>
            <div class="p-0">
                <table class="table table-sm table-borderless mb-0">
                    <thead>
                        <tr class="small text-muted">
                            <th class="ps-3">Región</th>
                            <th class="text-end pe-3">Registros</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in ViewBag.RegistrosPorRegion)
                        {
                            <tr>
                                <td class="ps-3 py-2">@item.Region</td>
                                <td class="text-end pe-3 py-2 fw-medium">@item.Total.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="border rounded bg-white">
            <div class="px-3 py-2 border-bottom bg-light bg-opacity-50">
                <span class="fw-medium small text-uppercase text-muted">Riqueza de especies por región</span>
            </div>
            <div class="p-0">
                <table class="table table-sm table-borderless mb-0">
                    <thead>
                        <tr class="small text-muted">
                            <th class="ps-3">Región</th>
                            <th class="text-end pe-3">Especies distintas</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in ViewBag.EspeciesPorRegion)
                        {
                            <tr>
                                <td class="ps-3 py-2">@item.Region</td>
                                <td class="text-end pe-3 py-2 fw-medium">@item.EspeciesDistintas.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="border rounded bg-white">
            <div class="px-3 py-2 border-bottom bg-light bg-opacity-50">
                <span class="fw-medium small text-uppercase text-muted">Top 10 especies más registradas</span>
            </div>
            <div class="p-0">
                <table class="table table-sm table-borderless mb-0">
                    <thead>
                        <tr class="small text-muted">
                            <th class="ps-3">#</th>
                            <th>Especie</th>
                            <th class="text-end pe-3">Registros</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int i = 1; }
                        @foreach (var item in ViewBag.TopEspecies)
                        {
                            <tr>
                                <td class="ps-3 text-muted">@i</td>
                                <td>@item.Especie</td>
                                <td class="text-end pe-3 fw-medium">@item.TotalRegistros.ToString("N0")</td>
                            </tr>
                            i++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="border rounded bg-white">
            <div class="px-3 py-2 border-bottom bg-light bg-opacity-50">
                <span class="fw-medium small text-uppercase text-muted">Especies por estado de conservación</span>
            </div>
            <div class="p-0">
                <table class="table table-sm table-borderless mb-0">
                    <thead>
                        <tr class="small text-muted">
                            <th class="ps-3">Código</th>
                            <th>Estado</th>
                            <th class="text-end pe-3">Especies</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in ViewBag.EspeciesPorEstado)
                        {
                            <tr>
                                <td class="ps-3"><span class="border px-1 small">@item.Code</span></td>
                                <td>@item.Name</td>
                                <td class="text-end pe-3 fw-medium">@item.Total.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="border rounded bg-white">
            <div class="px-3 py-2 border-bottom bg-light bg-opacity-50">
                <span class="fw-medium small text-uppercase text-muted">Top 10 investigadores</span>
            </div>
            <div class="p-0">
                <table class="table table-sm table-borderless mb-0">
                    <thead>
                        <tr class="small text-muted">
                            <th class="ps-3">#</th>
                            <th>Nombre</th>
                            <th>Institución</th>
                            <th class="text-end pe-3">Registros</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int j = 1; }
                        @foreach (var item in ViewBag.TopInvestigadores)
                        {
                            <tr>
                                <td class="ps-3 text-muted">@j</td>
                                <td>@item.Name</td>
                                <td class="small text-muted">@item.Institution</td>
                                <td class="text-end pe-3 fw-medium">@item.TotalRegistros.ToString("N0")</td>
                            </tr>
                            j++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="border rounded bg-white">
            <div class="px-3 py-2 border-bottom bg-light bg-opacity-50">
                <span class="fw-medium small text-uppercase text-muted">Registros por año</span>
            </div>
            <div class="p-0">
                <table class="table table-sm table-borderless mb-0">
                    <thead>
                        <tr class="small text-muted">
                            <th class="ps-3">Año</th>
                            <th class="text-end pe-3">Registros</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in ViewBag.RegistrosPorAnio)
                        {
                            <tr>
                                <td class="ps-3 py-2">@item.Anio</td>
                                <td class="text-end pe-3 py-2 fw-medium">@item.Total.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
