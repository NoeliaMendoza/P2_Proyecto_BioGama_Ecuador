@model BioGamaEcuador.Models.Record

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Record</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Species)
        </dt>
        <dd class="col-sm-10">
            @Model.Species?.CommonName
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Location)
        </dt>
        <dd class="col-sm-10">
            @Model.Location?.PlaceName
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Researcher)
        </dt>
        <dd class="col-sm-10">
            @Model.Researcher?.Name
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.DiscoveryDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.DiscoveryDate)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ObservedQuantity)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ObservedQuantity)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Observations)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Observations)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.IsActive)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.IsActive)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.CreatedAt)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.CreatedAt)
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Back to List</a>
    </form>
</div>
