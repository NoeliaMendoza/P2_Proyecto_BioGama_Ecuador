@model BioGamaEcuador.Models.Record

@{
    ViewData["Title"] = "Eliminar registro";
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Registros</a></li>
            <li class="breadcrumb-item active" aria-current="page">Eliminar</li>
        </ol>
    </nav>

    <div class="card shadow-sm border-0">
        <div class="card-body text-center py-5">
            <i class="fa-regular fa-circle-exclamation text-danger" style="font-size:3rem;"></i>
            <h4 class="mt-3">¿Está seguro de que desea eliminar este registro?</h4>
            <p class="text-muted mb-4">Esta acción desactivará el registro. No se eliminará permanentemente.</p>

            <dl class="row text-start mx-auto" style="max-width:500px;">
                <dt class="col-sm-5 text-muted">Especie</dt>
                <dd class="col-sm-7">@Model.Species?.CommonName</dd>
                <dt class="col-sm-5 text-muted">Ubicación</dt>
                <dd class="col-sm-7">@Model.Location?.PlaceName</dd>
                <dt class="col-sm-5 text-muted">Investigador</dt>
                <dd class="col-sm-7">@Model.Researcher?.Name</dd>
                <dt class="col-sm-5 text-muted">Fecha de descubrimiento</dt>
                <dd class="col-sm-7">@Model.DiscoveryDate.ToString("dd/MM/yyyy")</dd>
                <dt class="col-sm-5 text-muted">Cantidad observada</dt>
                <dd class="col-sm-7">@Model.ObservedQuantity</dd>
            </dl>

            <form asp-action="Delete" class="mt-4">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger me-2"><i class="fa-regular fa-trash-can me-1"></i>Eliminar</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </form>
        </div>
    </div>
</div>
