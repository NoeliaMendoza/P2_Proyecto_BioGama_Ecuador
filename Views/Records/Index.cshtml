@model List<BioGamaEcuador.Models.Record>

@{
    ViewData["Title"] = "Registros";
}

@using System.Security.Claims
@{
    var currentEmail = User.FindFirst(ClaimTypes.Email)?.Value ?? User.Identity?.Name;
}

<div class="mb-3">
    <div class="d-flex justify-content-between align-items-center">
        <h2>Registros <span class="badge bg-secondary ms-2">Total: @ViewBag.TotalItems</span></h2>
        @if (User.IsInRole("Administrador") || User.IsInRole("Investigador"))
        {
            <a class="btn btn-primary btn-sm" asp-action="Create">Crear nuevo</a>
        }
    </div>

    <form method="get" asp-action="Index" class="mt-3">
        <div class="row g-2 align-items-center">
            <div class="col-12 col-md-4">
                <input type="text" name="busqueda" class="form-control" placeholder="Texto libre…"
                       value="@ViewBag.Busqueda" />
            </div>
            <div class="col-6 col-md-2">
                <select name="speciesId" class="form-select">
                    <option value="">Todas las especies</option>
                    @foreach (var s in
                    (IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>?)ViewBag.SpeciesList ??
                    Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>())
                    {
                        <option value="@s.Value" selected="@(ViewBag.SpeciesFiltro == s.Value)">@s.Text</option>
                    }
                </select>
            </div>
            <div class="col-6 col-md-2">
                <select name="locationId" class="form-select">
                    <option value="">Todos los lugares</option>
                    @foreach (var l in
                    (IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>?)ViewBag.LocationList ??
                    Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>())
                    {
                        <option value="@l.Value" selected="@(ViewBag.LocationFiltro == l.Value)">@l.Text</option>
                    }
                </select>
            </div>
            <div class="col-6 col-md-2">
                <select name="researcherId" class="form-select">
                    <option value="">Todos los investigadores</option>
                    @foreach (var r in
                    (IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>?)ViewBag.ResearcherList ??
                    Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>())
                    {
                        <option value="@r.Value" selected="@(ViewBag.ResearcherFiltro == r.Value)">@r.Text</option>
                    }
                </select>
            </div>
            <div class="col-6 col-md-2 d-flex gap-2">
                <button class="btn btn-outline-secondary w-100">Filtrar</button>
                <a asp-action="Index" class="btn btn-outline-secondary w-100">Limpiar</a>
            </div>
        </div>
    </form>
</div>
<div class="table-responsive">
    <table class="table table-striped table-hover table-bordered align-middle">
        <thead class="table-light">
            <tr>
                <th>Especie</th>
                <th>Ubicación</th>
                <th>Investigador</th>
                <th>Fecha descubrimiento</th>
                <th>Cantidad observada</th>
                <th>Observaciones</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Species?.CommonName</td>
                    <td>@item.Location?.PlaceName</td>
                    <td>@item.Researcher?.Name</td>
                    <td>@item.DiscoveryDate.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@item.ObservedQuantity</td>
                    <td>
                        @if (item.Observations?.Length > 60)
                        {
                            @item.Observations.Substring(0, 60)
                            <text>…</text>
                        }
                        else
                        {
                            @item.Observations
                        }
                    </td>
                    <td>
                        <div class="btn-group" role="group">
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Ver</a>

                            @if (User.IsInRole("Administrador") || (User.IsInRole("Investigador") &&
                        string.Equals(item.Researcher?.Email, currentEmail, StringComparison.OrdinalIgnoreCase)))
                            {
                                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Editar</a>
                            }

                            @if (User.IsInRole("Administrador"))
                            {
                                <a class="btn btn-sm btn-outline-danger" asp-action="Delete"
                                   asp-route-id="@item.Id">Eliminar</a>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<nav class="mt-3" aria-label="Paginación">
    <ul class="pagination justify-content-center">
        @{
            int paginaActual = (int)ViewBag.PaginaActual;
            int totalPaginas = (int)ViewBag.TotalPaginas;
            int rango = 9;
            int inicio = Math.Max(1, paginaActual - rango);
            int fin = Math.Min(totalPaginas, paginaActual + rango);
        }

        <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
            <a class="page-link" asp-action="Index" asp-route-pagina="1" asp-route-busqueda="@ViewBag.Busqueda"
               asp-route-speciesId="@ViewBag.SpeciesFiltro" asp-route-locationId="@ViewBag.LocationFiltro"
               asp-route-researcherId="@ViewBag.ResearcherFiltro">&laquo;</a>
        </li>
        <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
            <a class="page-link" asp-action="Index" asp-route-pagina="@(paginaActual - 1)"
               asp-route-busqueda="@ViewBag.Busqueda" asp-route-speciesId="@ViewBag.SpeciesFiltro"
               asp-route-locationId="@ViewBag.LocationFiltro"
               asp-route-researcherId="@ViewBag.ResearcherFiltro">&lsaquo;</a>
        </li>

        @if (inicio > 1)
        {
            <li class="page-item disabled"><span class="page-link">…</span></li>
        }

        @for (int i = inicio; i <= fin; i++)
        {
            <li class="page-item @(i == paginaActual ? "active" : "")">
                <a class="page-link" asp-action="Index" asp-route-pagina="@i" asp-route-busqueda="@ViewBag.Busqueda"
                   asp-route-speciesId="@ViewBag.SpeciesFiltro" asp-route-locationId="@ViewBag.LocationFiltro"
                   asp-route-researcherId="@ViewBag.ResearcherFiltro">@i</a>
            </li>
        }

        @if (fin < totalPaginas)
        {
            <li class="page-item disabled"><span class="page-link">…</span></li>
        }

        <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
            <a class="page-link" asp-action="Index" asp-route-pagina="@(paginaActual + 1)"
               asp-route-busqueda="@ViewBag.Busqueda" asp-route-speciesId="@ViewBag.SpeciesFiltro"
               asp-route-locationId="@ViewBag.LocationFiltro"
               asp-route-researcherId="@ViewBag.ResearcherFiltro">&rsaquo;</a>
        </li>
        <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
            <a class="page-link" asp-action="Index" asp-route-pagina="@totalPaginas"
               asp-route-busqueda="@ViewBag.Busqueda" asp-route-speciesId="@ViewBag.SpeciesFiltro"
               asp-route-locationId="@ViewBag.LocationFiltro"
               asp-route-researcherId="@ViewBag.ResearcherFiltro">&raquo;</a>
        </li>
    </ul>
    <p class="text-center text-muted small">Página @paginaActual de @totalPaginas</p>
</nav>