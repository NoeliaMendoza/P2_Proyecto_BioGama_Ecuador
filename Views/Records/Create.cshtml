@model BioGamaEcuador.Models.Record

@{
    ViewData["Title"] = "Nuevo Registro";
    var isCurrentInvestigator = ViewData["IsCurrentInvestigator"] as bool? ?? false;
    var currentResearcherName = ViewData["CurrentResearcherName"] as string ?? string.Empty;
}

<h2>Nuevo Registro</h2>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group mb-3">
                <label asp-for="SpeciesId" class="control-label">Especie</label>
                <select asp-for="SpeciesId" class="form-control" asp-items="ViewBag.SpeciesId">
                    <option value="">-- Seleccione una especie --</option>
                </select>
                <span asp-validation-for="SpeciesId" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="LocationId" class="control-label">Ubicación</label>
                <select asp-for="LocationId" class="form-control" asp-items="ViewBag.LocationId">
                    <option value="">-- Seleccione una ubicación --</option>
                </select>
                <span asp-validation-for="LocationId" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="ResearcherId" class="control-label">Investigador</label>
                @if (isCurrentInvestigator)
                {
                    <input type="hidden" asp-for="ResearcherId" />
                    <input class="form-control" value="@currentResearcherName" readonly />
                }
                else
                {
                    <select asp-for="ResearcherId" class="form-control" asp-items="ViewBag.ResearcherId">
                        <option value="">-- Seleccione un investigador --</option>
                    </select>
                }
                <span asp-validation-for="ResearcherId" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="DiscoveryDate" class="control-label">Fecha del hallazgo</label>
                <input asp-for="DiscoveryDate" type="date" class="form-control" />
                <span asp-validation-for="DiscoveryDate" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="ObservedQuantity" class="control-label">Cantidad observada</label>
                <input asp-for="ObservedQuantity" class="form-control" />
                <span asp-validation-for="ObservedQuantity" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Observations" class="control-label">Observaciones</label>
                <textarea asp-for="Observations" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Observations" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Guardar" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
