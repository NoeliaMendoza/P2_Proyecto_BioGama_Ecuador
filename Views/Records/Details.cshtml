@model BioGamaEcuador.Models.Record
@{
    ViewData["Title"] = "Registro #" + Model.Id;
}

<div class="mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fa-solid fa-arrow-left me-1"></i>Volver al
        listado</a>
    </div>
    <div class="card shadow-sm">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0"><i class="fa-solid fa-clipboard-list me-2"></i>Registro de observación #@Model.Id</h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="card border-0 bg-light p-3 text-center h-100">
                        <div style="font-size:2rem;"><i class="fa-solid fa-paw text-success"></i></div>
                        <div class="small text-muted mt-1">Especie</div>
                        <div class="fw-bold">@(Model.Species?.CommonName ?? "—")</div>
                        <div class="fst-italic text-muted small">@Model.Species?.ScientificName</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 bg-light p-3 text-center h-100">
                        <div style="font-size:2rem;"><i class="fa-solid fa-location-dot text-danger"></i></div>
                        <div class="small text-muted mt-1">Ubicación</div>
                        <div class="fw-bold">@(Model.Location?.PlaceName ?? "—")</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 bg-light p-3 text-center h-100">
                        <div style="font-size:2rem;"><i class="fa-solid fa-user-graduate text-primary"></i></div>
                        <div class="small text-muted mt-1">Investigador</div>
                        <div class="fw-bold">@(Model.Researcher?.Name ?? "—")</div>
                    </div>
                </div>
            </div>
            <hr />
            <dl class="row mb-0">
                <dt class="col-sm-4"><i class="fa-solid fa-calendar-day me-1 text-muted"></i>Fecha del hallazgo</dt>
                <dd class="col-sm-8">@Model.DiscoveryDate.ToString("dd/MM/yyyy")</dd>

                <dt class="col-sm-4"><i class="fa-solid fa-hashtag me-1 text-muted"></i>Cantidad observada</dt>
                <dd class="col-sm-8"><span class="badge bg-success fs-6">@Model.ObservedQuantity individuos</span></dd>

                <dt class="col-sm-4"><i class="fa-solid fa-note-sticky me-1 text-muted"></i>Observaciones</dt>
                <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.Observations) ? "—" : Model.Observations)</dd>

                <dt class="col-sm-4"><i class="fa-solid fa-clock me-1 text-muted"></i>Registrado el</dt>
                <dd class="col-sm-8">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>
            </dl>
            @using System.Security.Claims
        @{
                var currentEmail = User.FindFirst(ClaimTypes.Email)?.Value ?? User.Identity?.Name;
                bool puedeEditar = User.IsInRole("Administrador") || (User.IsInRole("Investigador") &&
            string.Equals(Model.Researcher?.Email, currentEmail, StringComparison.OrdinalIgnoreCase));
                bool puedeEliminar = User.IsInRole("Administrador");
            }
            <div class="mt-4 d-flex gap-2">
                @if (puedeEditar)
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm"><i
                        class="fa-solid fa-pen me-1"></i>Editar</a>
                    }
                    @if (puedeEliminar)
                    {
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm"><i
                            class="fa-solid fa-trash me-1"></i>Eliminar</a>
                        }
                    </div>
                </div>
            </div>
