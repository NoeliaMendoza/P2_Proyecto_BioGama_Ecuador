@model List<BioGamaEcuador.Models.Species>

@{
    ViewData["Title"] = "Catálogo de Especies";
    Layout = "_LayoutPublic";
}

@* ── HERO HEADER ─────────────────────────────────────────────── *@
<div class="catalogo-hero">
    <div class="container">
        <h1>Catálogo de Especies</h1>
        <span class="badge-total">@ViewBag.TotalEspecies especies encontradas</span>
    </div>
</div>

@* ── FILTROS ─────────────────────────────────────────────────── *@
<div class="container mt-4 mb-3">
    <form method="get" asp-controller="Public" asp-action="Catalogo" class="catalogo-filtros">
        <div class="row g-2 align-items-end">

            <div class="col-12 col-md-4">
                <label class="form-label fw-semibold">Buscar</label>
                <input type="text" name="busqueda" class="form-control" placeholder="Nombre común o científico…"
                       value="@ViewBag.Busqueda" />
            </div>

            <div class="col-6 col-md-2">
                <label class="form-label fw-semibold">Familia</label>
                <select name="familia" class="form-select">
                    <option value="">Todas</option>
                    @foreach (var f in (List<string>)ViewBag.Familias)
                    {
                        <option value="@f" selected="@(ViewBag.FamiliaFiltro == f)">@f</option>
                    }
                </select>
            </div>

            <div class="col-6 col-md-2">
                <label class="form-label fw-semibold">Estado</label>
                <select name="estado" class="form-select">
                    <option value="">Todos</option>
                    @foreach (var e in (List<string>)ViewBag.Estados)
                    {
                        <option value="@e" selected="@(ViewBag.EstadoFiltro == e)">@e</option>
                    }
                </select>
            </div>

            <div class="col-6 col-md-2">
                <label class="form-label fw-semibold">Endémica</label>
                <select name="endemica" class="form-select">
                    <option value="">Todas</option>
                    <option value="true" selected="@(ViewBag.EndémicaFiltro == true)">Sí</option>
                    <option value="false" selected="@(ViewBag.EndémicaFiltro == false)">No</option>
                </select>
            </div>

            <div class="col-6 col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-success w-100">Filtrar</button>
                <a asp-controller="Public" asp-action="Catalogo" class="btn btn-outline-secondary w-100">Limpiar</a>
            </div>
        </div>
    </form>
</div>

@* ── LISTA DE ESPECIES (estilo FaunaWeb) ─────────────────────── *@
<div class="container">

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <p class="text-muted fs-5">No se encontraron especies con esos filtros.</p>
            <a asp-controller="Public" asp-action="Catalogo" class="btn btn-outline-success mt-2">
                Ver todas las especies
            </a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
            @foreach (var sp in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        @if (!string.IsNullOrWhiteSpace(sp.ImageUrl))
                        {
                            var imageUrl = sp.ImageUrl.Trim();
                            var imageSrc = imageUrl;

                            var isAbsolute = Uri.TryCreate(imageUrl, UriKind.Absolute, out _);
                            if (isAbsolute)
                            {
                                imageSrc = imageUrl.Contains(" ") ? imageUrl.Replace(" ", "%20") : imageUrl;
                            }
                            else
                            {
                                if (!imageUrl.StartsWith("~/") && !imageUrl.StartsWith("/"))
                                {
                                    imageUrl = "~/images/" + imageUrl.TrimStart('/');
                                }
                                imageSrc = Url.Content(imageUrl);
                            }

                            <img src="@imageSrc" alt="@sp.CommonName" class="card-img-top img-fluid"
                                 style="max-height:220px; object-fit:cover;" />
                        }
                        else
                        {
                            var label = sp.Family?.Name ?? sp.CommonName ?? "Especie";
                            <div class="card-img-top bg-light d-flex flex-column align-items-center justify-content-center text-muted"
                                 style="height:220px;">
                                <i class="bi bi-image" style="font-size:48px;color:#6b7280;"></i>
                                <small class="mt-2">@label</small>
                            </div>
                        }

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title mb-1">@sp.CommonName</h5>
                            <p class="text-muted small mb-3"><em>@sp.ScientificName</em></p>

                            <div class="mb-2">
                                @if (sp.Family != null)
                                {
                                    <span class="badge bg-secondary me-1">@sp.Family.Name</span>
                                }
                                @if (sp.IsEndemic)
                                {
                                    <span class="badge bg-warning text-dark">Endémica</span>
                                }
                            </div>

                            @if (!string.IsNullOrWhiteSpace(sp.Description))
                            {
                                <p class="card-text text-truncate mb-3">@sp.Description</p>
                            }

                            <div class="mt-auto d-flex flex-column gap-2">
                                <a asp-controller="Public" asp-action="DetalleEspecie" asp-route-id="@sp.Id"
                                   class="btn btn-success btn-sm w-100">Ver ficha</a>
                                <div>
                                    <span class="badge bg-info text-dark me-1">@(sp.ConservationStatus?.Code ?? "N/D")</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @* ── PAGINACIÓN ── *@
    @{
        int paginaActual = (int)ViewBag.PaginaActual;
        int totalPaginas = (int)ViewBag.TotalPaginas;
        int rango = 9;
        int inicio = Math.Max(1, paginaActual - rango);
        int fin = Math.Min(totalPaginas, paginaActual + rango);
    }
    @if (totalPaginas > 1)
    {
        <nav class="mt-4 mb-5" aria-label="Paginación catálogo">
            <ul class="pagination justify-content-center flex-wrap">
                <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                    <a class="page-link" asp-controller="Public" asp-action="Catalogo" asp-route-pagina="1"
                       asp-route-busqueda="@ViewBag.Busqueda" asp-route-familia="@ViewBag.FamiliaFiltro"
                       asp-route-estado="@ViewBag.EstadoFiltro" asp-route-endemica="@ViewBag.EndémicaFiltro">&laquo;</a>
                </li>

                <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                    <a class="page-link" asp-controller="Public" asp-action="Catalogo"
                       asp-route-pagina="@(paginaActual - 1)" asp-route-busqueda="@ViewBag.Busqueda"
                       asp-route-familia="@ViewBag.FamiliaFiltro" asp-route-estado="@ViewBag.EstadoFiltro"
                       asp-route-endemica="@ViewBag.EndémicaFiltro">&lsaquo;</a>
                </li>

                @if (inicio > 1)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }

                @for (int i = inicio; i <= fin; i++)
                {
                    <li class="page-item @(i == paginaActual ? "active" : "")">
                        <a class="page-link" asp-controller="Public" asp-action="Catalogo" asp-route-pagina="@i"
                           asp-route-busqueda="@ViewBag.Busqueda" asp-route-familia="@ViewBag.FamiliaFiltro"
                           asp-route-estado="@ViewBag.EstadoFiltro" asp-route-endemica="@ViewBag.EndémicaFiltro">@i</a>
                    </li>
                }

                @if (fin < totalPaginas)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }

                <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                    <a class="page-link" asp-controller="Public" asp-action="Catalogo"
                       asp-route-pagina="@(paginaActual + 1)" asp-route-busqueda="@ViewBag.Busqueda"
                       asp-route-familia="@ViewBag.FamiliaFiltro" asp-route-estado="@ViewBag.EstadoFiltro"
                       asp-route-endemica="@ViewBag.EndémicaFiltro">&rsaquo;</a>
                </li>

                <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                    <a class="page-link" asp-controller="Public" asp-action="Catalogo" asp-route-pagina="@totalPaginas"
                       asp-route-busqueda="@ViewBag.Busqueda" asp-route-familia="@ViewBag.FamiliaFiltro"
                       asp-route-estado="@ViewBag.EstadoFiltro" asp-route-endemica="@ViewBag.EndémicaFiltro">&raquo;</a>
                </li>
            </ul>
            <p class="text-center text-muted small">Página @paginaActual de @totalPaginas</p>
        </nav>
    }
</div>
