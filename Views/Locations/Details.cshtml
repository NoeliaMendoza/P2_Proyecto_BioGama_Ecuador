@model BioGamaEcuador.Models.Location
@{ ViewData["Title"] = Model.PlaceName; }

<div class="mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fa-solid fa-arrow-left me-1"></i>Volver al listado</a>
</div>
<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="fa-solid fa-location-dot me-2"></i>@Model.PlaceName</h5>
    </div>
    <div class="card-body">
        <div class="row g-3 mb-3">
            <div class="col-md-4">
                <div class="card border-0 bg-light p-3 text-center h-100">
                    <div style="font-size:2rem;"><i class="fa-solid fa-mountain text-secondary"></i></div>
                    <div class="small text-muted mt-1">Altitud</div>
                    <div class="fw-bold">@Model.Altitude m.s.n.m.</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 bg-light p-3 text-center h-100">
                    <div style="font-size:2rem;"><i class="fa-solid fa-globe text-info"></i></div>
                    <div class="small text-muted mt-1">Coordenadas</div>
                    <div class="fw-bold">Lat: @Model.Latitude°</div>
                    <div class="fw-bold">Lon: @Model.Longitude°</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 bg-light p-3 text-center h-100">
                    <div style="font-size:2rem;"><i class="fa-solid fa-leaf text-success"></i></div>
                    <div class="small text-muted mt-1">Reserva natural</div>
                    <div class="fw-bold">@(Model.NaturalReserve?.Name ?? "—")</div>
                </div>
            </div>
        </div>
        <dl class="row mb-0">
            <dt class="col-sm-4"><i class="fa-solid fa-calendar-days me-1 text-muted"></i>Registrado el</dt>
            <dd class="col-sm-8">@Model.CreatedAt.ToString("dd/MM/yyyy")</dd>
        </dl>
        <div class="mt-4 d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm"><i class="fa-solid fa-pen me-1"></i>Editar</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm"><i class="fa-solid fa-trash me-1"></i>Eliminar</a>
        </div>
    </div>
</div>
