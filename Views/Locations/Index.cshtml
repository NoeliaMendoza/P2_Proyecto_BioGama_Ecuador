@model List<BioGamaEcuador.Models.Location>

@{
    ViewData["Title"] = "Ubicaciones";
}

<div class="mb-3">
    <div class="d-flex justify-content-between align-items-center">
        <h2>Ubicaciones <span class="badge bg-secondary ms-2">Total: @ViewBag.TotalItems</span></h2>
        @if (User.IsInRole("Administrador") || User.IsInRole("Investigador"))
        {
            <a class="btn btn-primary btn-sm" asp-action="Create">Crear nueva</a>
        }
    </div>

    <form method="get" asp-action="Index" class="mt-3">
        <div class="row g-2 align-items-center">
            <div class="col-12 col-md-5">
                <input type="text" name="busqueda" class="form-control" placeholder="Buscar por lugar…"
                       value="@ViewBag.Busqueda" />
            </div>
            <div class="col-7 col-md-4">
                <select name="reserva" class="form-select">
                    <option value="">Todas las reservas</option>
                    @foreach (var r in (IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>?)ViewBag.Reservas
                    ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>())
                    {
                        <option value="@r.Value" selected="@(ViewBag.ReservaFiltro == r.Value)">@r.Text</option>
                    }
                </select>
            </div>
            <div class="col-5 col-md-3 d-flex gap-2">
                <button class="btn btn-outline-secondary w-100">Filtrar</button>
                <a asp-action="Index" class="btn btn-outline-secondary w-100">Limpiar</a>
            </div>
        </div>
    </form>
</div>
<div class="table-responsive">
    <table class="table table-striped table-hover table-bordered align-middle">
        <thead class="table-light">
            <tr>
                <th>Lugar</th>
                <th>Altitud</th>
                <th>Latitud</th>
                <th>Longitud</th>
                <th>Reserva</th>
                @* <th>Creado</th> *@
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.PlaceName</td>
                    <td>@item.Altitude</td>
                    <td>@item.Latitude</td>
                    <td>@item.Longitude</td>
                    <td>@item.NaturalReserve?.Name</td>
                    @* <td>@item.CreatedAt</td> *@
                    <td>
                        <div class="btn-group" role="group" aria-label="Acciones">
                            @if (User.IsInRole("Administrador") || User.IsInRole("Investigador"))
                            {
                                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Editar</a>
                            }
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Ver</a>
                            @if (User.IsInRole("Administrador"))
                            {
                                <a class="btn btn-sm btn-outline-danger" asp-action="Delete"
                                   asp-route-id="@item.Id">Eliminar</a>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<nav class="mt-3" aria-label="Paginación">
    <ul class="pagination justify-content-center">
        @{
            int paginaActual = (int)ViewBag.PaginaActual;
            int totalPaginas = (int)ViewBag.TotalPaginas;
            int rango = 9;
            int inicio = Math.Max(1, paginaActual - rango);
            int fin = Math.Min(totalPaginas, paginaActual + rango);
        }

        @* « Primera *@
        <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
            <a class="page-link" asp-action="Index" asp-route-pagina="1" asp-route-busqueda="@ViewBag.Busqueda"
               asp-route-reserva="@ViewBag.ReservaFiltro">&laquo;</a>
        </li>

        @* ‹ Anterior *@
        <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
            <a class="page-link" asp-action="Index" asp-route-pagina="@(paginaActual - 1)"
               asp-route-busqueda="@ViewBag.Busqueda" asp-route-reserva="@ViewBag.ReservaFiltro">&lsaquo;</a>
        </li>

        @* … izquierdo *@
        @if (inicio > 1)
        {
            <li class="page-item disabled"><span class="page-link">…</span></li>
        }

        @* Rango central *@
        @for (int i = inicio; i <= fin; i++)
        {
            <li class="page-item @(i == paginaActual ? "active" : "")">
                <a class="page-link" asp-action="Index" asp-route-pagina="@i" asp-route-busqueda="@ViewBag.Busqueda"
                   asp-route-reserva="@ViewBag.ReservaFiltro">@i</a>
            </li>
        }

        @* … derecho *@
        @if (fin < totalPaginas)
        {
            <li class="page-item disabled"><span class="page-link">…</span></li>
        }

        @* › Siguiente *@
        <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
            <a class="page-link" asp-action="Index" asp-route-pagina="@(paginaActual + 1)"
               asp-route-busqueda="@ViewBag.Busqueda" asp-route-reserva="@ViewBag.ReservaFiltro">&rsaquo;</a>
        </li>

        @* » Última *@
        <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
            <a class="page-link" asp-action="Index" asp-route-pagina="@totalPaginas"
               asp-route-busqueda="@ViewBag.Busqueda" asp-route-reserva="@ViewBag.ReservaFiltro">&raquo;</a>
        </li>
    </ul>
    <p class="text-center text-muted small">Página @ViewBag.PaginaActual de @ViewBag.TotalPaginas</p>
</nav>
