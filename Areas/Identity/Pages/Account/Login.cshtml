@page
@model LoginModel

@{
    ViewData["Title"] = "Iniciar sesión";
}

<div class="d-flex align-items-center justify-content-center min-vh-75">
    <div class="row justify-content-center w-100">
        <div class="col-md-6">
            <div class="card border-success shadow-sm">
                <div class="card-header bg-success text-white">
                    <h2 class="card-title mb-0">@ViewData["Title"]</h2>
                </div>
                <div class="card-body">
                    <p class="text-muted">Accede con tu cuenta para administrar y registrar datos.</p>
                    <hr />
                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control" autocomplete="username"
                                   aria-required="true" placeholder="name@example.com" />
                            <label for="Input_Email">Correo electrónico</label>
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password" class="form-control" autocomplete="current-password"
                                   aria-required="true" placeholder="password" />
                            <label for="Input_Password">Contraseña</label>
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>
                        <div class="form-check mb-3">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            <label class="form-check-label" asp-for="Input.RememberMe">Recordarme</label>
                        </div>
                        <div class="d-grid mb-3">
                            <button id="login-submit" type="submit" class="btn btn-success btn-lg">Iniciar
                                sesión</button>
                            </div>
                            <div class="mt-3">
                                <a id="forgot-password" asp-page="./ForgotPassword">¿Olvidaste tu contraseña?</a>
                                <span class="d-block mt-2">¿No tienes cuenta? <a asp-page="./Register"
                                                                                     asp-route-returnUrl="@Model.ReturnUrl">Regístrate</a></span>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @section Scripts {
            <partial name="_ValidationScriptsPartial" />
        }
